# ═══════════════════════════════════════════════════════════════════════════
#  TradingIA — Configurazione
#  Copia in .env e compila con le tue credenziali
# ═══════════════════════════════════════════════════════════════════════════

# ── Generale ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENV=development

# ─────────────────────────────────────────────────────────────────────────────
#  BROKER ATTIVO
#  Valori possibili: paper | ig | oanda | alpaca | ccxt
#  - paper:  nessuna credenziale, trading simulato (default sicuro)
#  - ig:     IG Markets (forex, indici, oro CFD)
#  - oanda:  OANDA (forex + XAU/USD, conto demo gratuito)
# ─────────────────────────────────────────────────────────────────────────────
BROKER_ACTIVE_BROKER=paper

# ── IG Markets ──────────────────────────────────────────────────────────────
# Conto demo GRATUITO: https://www.ig.com/it/trading-account/demo-account
# API key:             https://labs.ig.com/ → My Applications → Create
# ACCOUNT_TYPE: "demo" per paper trading, "live" per soldi reali
# ACCOUNT_ID: lascia vuoto per usare il default del tuo profilo

BROKER_IG_API_KEY=your_ig_api_key_here
BROKER_IG_USERNAME=your_ig_username_email
BROKER_IG_PASSWORD=your_ig_password
BROKER_IG_ACCOUNT_TYPE=demo
BROKER_IG_ACCOUNT_ID=

# ── OANDA ───────────────────────────────────────────────────────────────────
# Conto practice (demo) GRATUITO: https://www.oanda.com/it-it/
# API token: MyAccount → Manage API Access → Generate new token
# Account ID: MyAccount → Account Details (formato: 101-004-XXXXXXX-001)
# ENVIRONMENT: "practice" (demo) o "live"

BROKER_OANDA_API_TOKEN=your_oanda_api_token_here
BROKER_OANDA_ACCOUNT_ID=101-004-XXXXXXX-001
BROKER_OANDA_ENVIRONMENT=practice

# ── Alpaca (azioni USA) ─────────────────────────────────────────────────────
BROKER_ALPACA_API_KEY=your_alpaca_api_key
BROKER_ALPACA_SECRET_KEY=your_alpaca_secret_key
BROKER_ALPACA_PAPER=true

# ── CCXT (crypto) ───────────────────────────────────────────────────────────
BROKER_CCXT_EXCHANGE=binance
BROKER_CCXT_API_KEY=your_exchange_api_key
BROKER_CCXT_SECRET=your_exchange_secret
BROKER_CCXT_SANDBOX=true

# ─────────────────────────────────────────────────────────────────────────────
#  DATI DI MERCATO
# ─────────────────────────────────────────────────────────────────────────────
DATA_ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# ─────────────────────────────────────────────────────────────────────────────
#  NOTIFICHE TELEGRAM
#  1. Crea bot su Telegram: https://t.me/BotFather → /newbot
#  2. Ottieni il chat ID: https://t.me/userinfobot
# ─────────────────────────────────────────────────────────────────────────────
NOTIFY_TELEGRAM_TOKEN=your_telegram_bot_token
NOTIFY_TELEGRAM_CHAT_ID=your_chat_id
NOTIFY_NOTIFY_ON_TRADE=true
NOTIFY_NOTIFY_ON_ALERT=true

# ─────────────────────────────────────────────────────────────────────────────
#  RISK MANAGEMENT (valori consigliati per account piccoli)
# ─────────────────────────────────────────────────────────────────────────────
RISK_MAX_PORTFOLIO_RISK_PCT=1.0     # % capitale rischiato per trade
RISK_MAX_DRAWDOWN_PCT=8.0           # blocca trading se drawdown supera questo %
RISK_MAX_OPEN_POSITIONS=2           # max posizioni aperte insieme
RISK_MAX_POSITION_SIZE_PCT=10.0     # max % portfolio per singola posizione
RISK_KELLY_FRACTION=0.25            # Kelly frazionale (conservativo)
RISK_USE_TRAILING_STOP=true
RISK_TRAILING_STOP_PCT=1.5

# ─────────────────────────────────────────────────────────────────────────────
#  AI / ML
# ─────────────────────────────────────────────────────────────────────────────
ML_MIN_CONFIDENCE=0.6
ML_LOOKBACK_WINDOW=60
ML_RETRAIN_INTERVAL_HOURS=24

# ─────────────────────────────────────────────────────────────────────────────
#  NOTIFICHE EMAIL (opzionale)
# ─────────────────────────────────────────────────────────────────────────────
NOTIFY_EMAIL_SMTP=smtp.gmail.com
NOTIFY_EMAIL_FROM=your_email@gmail.com
NOTIFY_EMAIL_TO=your_email@gmail.com
NOTIFY_EMAIL_PASSWORD=your_gmail_app_password

# ─────────────────────────────────────────────────────────────────────────────
#  DASHBOARD (FastAPI — opzionale)
# ─────────────────────────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_SECRET_KEY=change-this-in-production
