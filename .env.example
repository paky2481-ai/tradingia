# TradingIA Configuration
# Copy this file to .env and fill in your values

# ── General ────────────────────────────────────────────────
LOG_LEVEL=INFO
ENV=development

# ── Alpaca (stocks/ETFs) ────────────────────────────────────
BROKER_ALPACA_API_KEY=your_alpaca_api_key
BROKER_ALPACA_SECRET_KEY=your_alpaca_secret_key
BROKER_ALPACA_PAPER=true

# ── CCXT (crypto exchanges) ────────────────────────────────
BROKER_CCXT_EXCHANGE=binance
BROKER_CCXT_API_KEY=your_exchange_api_key
BROKER_CCXT_SECRET=your_exchange_secret
BROKER_CCXT_SANDBOX=true

# ── Data Sources ────────────────────────────────────────────
DATA_ALPHA_VANTAGE_KEY=your_alpha_vantage_key

# ── Risk Parameters ─────────────────────────────────────────
RISK_MAX_PORTFOLIO_RISK_PCT=2.0
RISK_MAX_DRAWDOWN_PCT=15.0
RISK_MAX_OPEN_POSITIONS=10

# ── Notifications ────────────────────────────────────────────
NOTIFY_TELEGRAM_TOKEN=your_telegram_bot_token
NOTIFY_TELEGRAM_CHAT_ID=your_chat_id

# ── Dashboard ────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_SECRET_KEY=change-this-in-production
